# Copy to .env.local for local development
DJANGO_SETTINGS_MODULE=config.settings.local
SECRET_KEY=change-me-use-a-long-random-string

# Comma-separated list of allowed hosts (only needed in production)
ALLOWED_HOSTS=

# Email
DEFAULT_FROM_EMAIL=noreply@example.com
SERVER_EMAIL=errors@example.com
# DJANGO_ADMINS=Admin Name:admin@example.com

# Production SMTP (Postmark example)
EMAIL_URL=smtp+tls://<token>:<token>@smtp.postmarkapp.com:587

# Sentry (leave empty to disable)
SENTRY_DSN=

# MFA issuer name shown in authenticator apps
MFA_TOTP_ISSUER=vps-sqlite-saas

# Litestream S3 replication
LITESTREAM_REPLICA_URL=s3://mybucket/myapp/db
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=
