DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,web

DATABASE_URL=postgres://postgres:postgres@db:5432/postgres

REDIS_URL=redis://redis:6379

# S3-compatible storage — MinIO in local Compose
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=media
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ENDPOINT_URL=http://minio:9000
# Browser-accessible URL for generated media links (use localhost for host-side dev)
# AWS_S3_CUSTOM_DOMAIN=localhost:9000
# AWS_S3_URL_PROTOCOL=http:

EMAIL_URL=consolemail://
# DEFAULT_FROM_EMAIL=webmaster@localhost
# SERVER_EMAIL=root@example.com
# DJANGO_ADMINS=admin@example.com

# CORS — add your frontend origin in production
# DJANGO_CORS_ALLOWED_ORIGINS=https://app.example.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://app.example.com

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin
