DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgres://postgres:postgres@db:5432/postgres
REDIS_URL=redis://redis:6379
EMAIL_URL=consolemail://
DEFAULT_FROM_EMAIL=webmaster@localhost
# SERVER_EMAIL=root@example.com
# DJANGO_ADMINS=admin@example.com

# Anymail (Postmark) — required in production
# POSTMARK_SERVER_TOKEN=
# ANYMAIL_WEBHOOK_SECRET=

# S3 / MinIO storage — required in production
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=fly-app
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_URL_PROTOCOL=http:
AWS_S3_CUSTOM_DOMAIN=localhost:9000
# AWS_S3_REGION_NAME=us-east-1

# Analytics (GA4)
# ANALYTICS_ID=G-XXXXXXX

# Error reporting (GlitchTip / Sentry)
# SENTRY_DSN=
# SENTRY_RELEASE=

# Production only
# DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com
# DJANGO_BEHIND_PROXY=True
