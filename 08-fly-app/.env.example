DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com
# DJANGO_BEHIND_PROXY=False
# DJANGO_ADMINS=ops@example.com

DATABASE_URL=postgres://postgres:postgres@db:5432/postgres

REDIS_URL=redis://redis:6379

EMAIL_URL=consolemail://
DEFAULT_FROM_EMAIL=webmaster@localhost
# SERVER_EMAIL=root@example.com

# Anymail / Postmark (production only — EMAIL_BACKEND overrides EMAIL_URL when not DEBUG)
# POSTMARK_SERVER_TOKEN=
# ANYMAIL_WEBHOOK_SECRET=

# S3-compatible storage (MinIO locally)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ENDPOINT_URL=http://minio:9000
# AWS_S3_CUSTOM_DOMAIN=localhost:9000
# AWS_S3_URL_PROTOCOL=http:

# Analytics (GA4)
ANALYTICS_ID=
# ANALYTICS_HOST=

# Error reporting (GlitchTip / Sentry)
SENTRY_DSN=
# SENTRY_RELEASE=
