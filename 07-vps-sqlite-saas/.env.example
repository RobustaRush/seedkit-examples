DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Production: your real domain, e.g. https://example.com
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_SITE_DOMAIN=localhost
# Set True when running behind Caddy/nginx proxy
DJANGO_BEHIND_PROXY=False
DJANGO_SECURE_SSL_REDIRECT=True

DATABASE_URL=sqlite:////data/site.sqlite3
CACHE_DB_PATH=/data/cache.sqlite3

EMAIL_URL=smtp+tls://<token>:<token>@smtp.postmarkapp.com:587
DEFAULT_FROM_EMAIL=no-reply@example.com
SERVER_EMAIL=django@example.com
DJANGO_ADMINS=ops@example.com

SENTRY_DSN=
SENTRY_RELEASE=

# Litestream S3 replication
S3_ENDPOINT=https://s3.example.com
S3_BUCKET=my-bucket
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
