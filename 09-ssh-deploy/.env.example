DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Postgres in docker-compose)
DATABASE_URL=postgres://postgres:postgres@db:5432/postgres

# Redis
REDIS_URL=redis://redis:6379

# Analytics (Umami self-hosted — leave blank to disable)
ANALYTICS_ID=
ANALYTICS_HOST=

# Error reporting (Bugsink / Sentry DSN — leave blank to disable)
SENTRY_DSN=

# Backups (production only)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
DBBACKUP_BUCKET=
