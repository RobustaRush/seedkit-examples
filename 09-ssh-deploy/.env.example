# Copy to .env and fill in values for local development
DJANGO_SETTINGS_MODULE=config.settings.local
DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=127.0.0.1,localhost

# PostgreSQL (docker-compose.yml publishes on 127.0.0.1:5432)
DATABASE_URL=postgres://app:password@127.0.0.1:5432/app

# Redis (docker-compose.yml publishes on 127.0.0.1:6379)
REDIS_URL=redis://127.0.0.1:6379/0

# Umami analytics (self-hosted — leave blank to disable)
UMAMI_HOST=
UMAMI_WEBSITE_ID=

# Production only
# SENTRY_DSN=https://key@bugsink.example.com/1
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_ENVIRONMENT=production
