DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL — host port 5433 to avoid conflict with local Postgres on 5432
DATABASE_URL=postgres://app:app@127.0.0.1:5433/app

REDIS_URL=redis://127.0.0.1:6379/0

# Umami analytics (self-hosted) — leave blank to disable
UMAMI_WEBSITE_ID=
UMAMI_URL=

# Error reporting — Bugsink / Sentry DSN
SENTRY_DSN=
